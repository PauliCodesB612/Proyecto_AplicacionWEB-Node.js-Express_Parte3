{
  "info": {
    "name": "Modulo8-Pauli-Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "userId",
      "value": "1"
    },
    {
      "key": "taskId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Públicos",
      "item": [
        {
          "name": "Home",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/"
          }
        },
        {
          "name": "Status",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/status"
          }
        },
        {
          "name": "Public Endpoints",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/public/endpoints"
          }
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Paulina API\",\n  \"email\": \"paulina.api@example.com\",\n  \"password\": \"Pauli1234\",\n  \"role\": \"viewer\",\n  \"active\": true\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"paulina.admin@example.com\",\n  \"password\": \"Pauli1234\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        }
      ]
    },
    {
      "name": "Protegidos - Auth",
      "item": [
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/auth/me"
          }
        }
      ]
    },
    {
      "name": "Protegidos - Users",
      "item": [
        {
          "name": "Get Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/users"
          }
        },
        {
          "name": "Get Users Raw",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/users/raw"
          }
        },
        {
          "name": "Get User By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/users/{{userId}}"
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nuevo Usuario\",\n  \"email\": \"nuevo.usuario@example.com\",\n  \"password\": \"Pauli1234\",\n  \"role\": \"editor\",\n  \"active\": true\n}"
            },
            "url": "{{baseUrl}}/api/users"
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Usuario Actualizado\",\n  \"active\": false\n}"
            },
            "url": "{{baseUrl}}/api/users/{{userId}}"
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/users/{{userId}}"
          }
        },
        {
          "name": "Get User Tasks",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/users/{{userId}}/tasks"
          }
        },
        {
          "name": "Transactional User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Usuario Transaccional\",\n  \"email\": \"transaccional@example.com\",\n  \"password\": \"Pauli1234\",\n  \"role\": \"viewer\",\n  \"active\": true,\n  \"taskTitle\": \"Tarea inicial\",\n  \"forceError\": false\n}"
            },
            "url": "{{baseUrl}}/api/users/transactional"
          }
        }
      ]
    },
    {
      "name": "Protegidos - Tasks",
      "item": [
        {
          "name": "Get Tasks",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/tasks"
          }
        },
        {
          "name": "Get Task By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/tasks/{{taskId}}"
          }
        },
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Nueva tarea módulo 8\",\n  \"description\": \"Probando endpoint protegido\",\n  \"status\": \"pending\",\n  \"userId\": 1\n}"
            },
            "url": "{{baseUrl}}/api/tasks"
          }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"done\"\n}"
            },
            "url": "{{baseUrl}}/api/tasks/{{taskId}}"
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/tasks/{{taskId}}"
          }
        }
      ]
    },
    {
      "name": "Protegidos - Upload",
      "item": [
        {
          "name": "Upload Avatar",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "avatar",
                  "type": "file",
                  "src": ""
                },
                {
                  "key": "userId",
                  "value": "1",
                  "type": "text"
                }
              ]
            },
            "url": "{{baseUrl}}/api/upload"
          }
        }
      ]
    }
  ]
}